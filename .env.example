# ──────────────────────────────────────────────────────
# JOB TRACKER — Environment Variables
# ──────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values

# ── SUPABASE (Free) ──────────────────────────────────
# 1. Go to https://supabase.com → Create free account
# 2. Create a new project
# 3. Go to Settings → API → Copy these values:
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── GOOGLE GEMINI AI (optional) ───────────────────────
# Extraction still works without AI: Greenhouse/Workday JSON + page scrape + JSON-LD/heuristics.
# To force no AI (no quota, no key needed): DISABLE_GEMINI_AI=true
# DISABLE_GEMINI_AI=
# With GEMINI_API_KEY set: skip Gemini when Greenhouse/Workday returns full data (faster). Force AI anyway: FORCE_GEMINI_AI=true
# FORCE_GEMINI_AI=
# 1. Go to https://aistudio.google.com/apikey
# 2. Create an API key if you want LLM polish on messy pages
GEMINI_API_KEY=your_gemini_api_key
# Optional — default is gemini-2.5-flash (see Google AI model list)
# GEMINI_MODEL=gemini-2.5-flash

# ── OPTIONAL: lock the whole site (Vercel / any host) ─────────────────
# If set, visitors must open /login and paste this exact token once.
# Generate a long random string, e.g.: openssl rand -hex 32
# Leave unset for a normal public app (your Supabase RLS still applies to data).
# SITE_ACCESS_TOKEN=
