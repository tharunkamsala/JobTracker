# ──────────────────────────────────────────────────────
# JOB TRACKER — Environment Variables
# ──────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values

# ── SUPABASE (Free) ──────────────────────────────────
# 1. Go to https://supabase.com → Create free account
# 2. Create a new project
# 3. Go to Settings → API → Copy these values:
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── GOOGLE GEMINI AI (Free) ──────────────────────────
# 1. Go to https://aistudio.google.com/apikey
# 2. Click "Create API Key" (it's free, no billing needed)
# 3. Copy the key here:
GEMINI_API_KEY=your_gemini_api_key

# ── OPTIONAL: lock the whole site (Vercel / any host) ─────────────────
# If set, visitors must open /login and paste this exact token once.
# Generate a long random string, e.g.: openssl rand -hex 32
# Leave unset for a normal public app (your Supabase RLS still applies to data).
# SITE_ACCESS_TOKEN=
